---
/**
 * Layout principal del portafolio.
 * Incluye estilos globales, fuentes y navegación.
 */
interface Props {
    title: string;
}

const { title  = 'Sobre mi' } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title} — Junior B. Gonzales</title>
        <meta name="description" content="Portafolio personal de Junior B. Gonzales, Software Engineer." />
        <!-- Fuentes Geist desde NPM via CDN -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <style is:global>
            @import url('https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Geist+Mono:wght@100..900&display=swap');

            :root {
                --accent:     #bff66f;
                --text:       #000;
                --bg:         #fff;
                --bg-card:    #f5f5f4;
                --text-muted: #78716c;
                --text-card:  #57534f;
                --radius:     12px;
                --shadow:     0 8px 32px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.07);
            }

            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Geist', 'Segoe UI', sans-serif;
                background-color: var(--bg);
                color: var(--text);
                line-height: 1.7;
                min-height: 100vh;
            }

            a {
                color: inherit;
                text-decoration: none;
            }

            img { max-width: 100%; display: block; }

            .container {
                max-width: 900px;
                margin: 0 auto;
                padding: 0 1.5rem;
            }

            /* Navegación */
            .nav {
                border-bottom: 1px solid #e7e5e4;
                padding: 1.25rem 0;
                position: sticky;
                top: 0;
                background: rgba(255,255,255,0.90);
                backdrop-filter: blur(8px);
                z-index: 10;
            }

            .nav__inner {
                max-width: 900px;
                margin: 0 auto;
                padding: 0 1.5rem;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .nav__logo {
                font-weight: 700;
                font-size: 1rem;
                letter-spacing: -0.02em;
            }

            .nav__logo span {
                display: inline-block;
                background: var(--accent);
                color: var(--text);
                border-radius: 4px;
                padding: 0 5px;
                margin-left: 2px;
            }

            .nav__links {
                display: flex;
                gap: 1.75rem;
                list-style: none;
            }

            .nav__links a {
                font-size: 0.9rem;
                color: var(--text-muted);
                transition: color 0.15s;
            }

            .nav__links a:hover {
                color: var(--text);
            }

            /* Footer */
            .footer {
                border-top: 1px solid #e7e5e4;
                padding: 2rem 0;
                margin-top: 6rem;
                text-align: center;
                font-size: 0.85rem;
                color: var(--text-muted);
                font-family: 'Geist Mono', monospace;
            }
        </style>
    </head>
    <body>
        <nav class="nav">
            <div class="nav__inner">
                <span class="nav__logo">JuDev<span>.io</span></span>
                <ul class="nav__links">
                    <li><a href="/">Inicio</a></li>
                    <li><a href="/sobre-mi">Sobre mí</a></li>
                    <li><a href="/proyectos">Proyectos</a></li>
                </ul>
            </div>
        </nav>

        <slot />

        <footer class="footer">
            <div class="container">
                <p>© {new Date().getFullYear()} Junior Balcazar Gonzales · Hecho con Astro</p>
            </div>
        </footer>
    </body>
</html>
